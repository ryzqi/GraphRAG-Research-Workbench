TZ=Asia/Shanghai

# 安全占位模板：复制为 .env 后再填写，不要直接拿本文件作为可运行配置。
# 本地开发请把公开地址替换为本机/内网可达地址，不要把 loopback、本地口令或真实 secrets 回写到模板。
# 新部署优先使用分层变量名（CORE__/STORAGE__/WEB_SEARCH__/RESEARCH_GATE__/HTTP_CLIENT__）。
# secrets 应通过环境变量或 file secrets 注入；优先级为：
# 显式环境变量 > .env 文件 > file secrets > 代码默认值

CORE__APP_ENV=dev
CORE__APP_LOG_LEVEL=INFO
CORE__APP_CORS_ALLOW_ORIGINS=["http://<frontend-host>"]
NEXT_PUBLIC_API_BASE_URL=https://<backend-public-host>/api/v1
BACKEND_PUBLIC_BASE_URL=https://<backend-public-host>
FRONTEND_PUBLIC_BASE_URL=https://<frontend-public-host>
BACKEND_BIND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000

CORE__DATABASE_URL=postgresql+asyncpg://<db-user>:<db-password>@<db-host>:5432/<db-name>
CORE__REDIS_URL=redis://<redis-host>:6379/0
CORE__CELERY_BROKER_URL=redis://<redis-host>:6379/0
CORE__CELERY_RESULT_BACKEND=redis://<redis-host>:6379/1

CORE__EMBEDDING_BASE_URL=https://<embedding-provider>/v1
CORE__EMBEDDING_API_KEY=<set-via-secret-manager>
CORE__EMBEDDING_MODEL=<embedding-model>
CORE__MODEL_CONFIG_KMS_KEY=<set-via-secret-manager>

STORAGE__MINIO_ENDPOINT=<minio-host>:9000
STORAGE__MINIO_ACCESS_KEY=<set-via-secret-manager>
STORAGE__MINIO_SECRET_KEY=<set-via-secret-manager>
STORAGE__MINIO_BUCKET_UPLOADS=<uploads-bucket>
STORAGE__MINIO_BUCKET_EXPORTS=<exports-bucket>

WEB_SEARCH__SEARXNG_SEARCH_ENABLED=true
WEB_SEARCH__TAVILY_BASE_URL=https://api.tavily.com
WEB_SEARCH__SEARXNG_SEARCH_BASE_URL=https://<searxng-host>

RESEARCH_GATE__MIN_QUALITY_SCORE=0.75
RESEARCH_GATE__MAX_P95_MS=120000
RESEARCH_GATE__MAX_SESSION_COST_USD=2.0

HTTP_CLIENT__TIMEOUT_CONNECT_SECONDS=5
HTTP_CLIENT__TIMEOUT_READ_SECONDS=30
HTTP_CLIENT__TIMEOUT_WRITE_SECONDS=30
HTTP_CLIENT__TIMEOUT_POOL_SECONDS=5
