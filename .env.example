TZ=Asia/Shanghai

# --- 基础设施（Podman） ---
POSTGRES_USER=mkb
POSTGRES_PASSWORD=mkb
POSTGRES_DB=mkb
POSTGRES_PORT=5433

REDIS_PORT=6379
ETCD_PORT=2379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

MILVUS_PORT=19530
MILVUS_HTTP_PORT=9091

# SearXNG（本地搜索服务）
SEARXNG_PORT=18080
SEARXNG_BASE_URL=http://127.0.0.1:18080/
SEARXNG_SECRET=change-me-searxng-secret
SEARXNG_LIMITER=false
SEARXNG_IMAGE_PROXY=false
SEARXNG_VALKEY_URL=valkey://searxng_valkey:6379/0
# 如宿主机需要本地代理出网，填写一个“容器可访问”的代理地址；
# 不要写 127.0.0.1，可改为宿主机局域网 IP，例如 http://192.168.x.x:7890
SEARXNG_HTTP_PROXY=
SEARXNG_HTTPS_PROXY=
SEARXNG_NO_PROXY=localhost,127.0.0.1,postgres,redis,minio,milvus,etcd,searxng,searxng_valkey,*.local,10.*,172.16.*,172.17.*,172.18.*,172.19.*,172.30.*,172.31.*,192.168.*

# --- 后端（FastAPI） ---
APP_LOG_LEVEL=INFO

# 前端 API 基地址（不要包含 /api/v1，前端会自动拼接）
VITE_API_BASE_URL=http://127.0.0.1:8000

DATABASE_URL=postgresql+asyncpg://mkb:mkb@localhost:5433/mkb
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800

# Redis（缓存 + Celery）
REDIS_URL=redis://localhost:6379/0
REDIS_SOCKET_TIMEOUT_SECONDS=1.0
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=1.0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Milvus 配置
MILVUS_HOST=localhost
MILVUS_TEXT_ANALYZER=chinese
MILVUS_TEXT_ANALYZER_FILTERS=[]

LLM_TIMEOUT_SECONDS=600
LLM_MAX_INPUT_TOKENS=204800

# Web 搜索（Tavily + SearXNG，可选；jina_read 用于正文增强）
WEB_SEARCH_API_KEY=your-tavily-api-key
WEB_SEARCH_CACHE_ENABLED=true
WEB_SEARCH_CACHE_TTL_SECONDS=300
WEB_SEARCH_RETRY_MAX=2
WEB_SEARCH_RETRY_BACKOFF_SECONDS=1.5
WEB_SEARCH_RATE_LIMIT_PER_MINUTE=0
WEB_SEARCH_MAX_CONCURRENCY=5
WEB_SEARCH_DEFAULT_SEARCH_DEPTH=basic
WEB_SEARCH_DEFAULT_TIME_RANGE=month
WEB_SEARCH_DEFAULT_MAX_RESULTS=5
WEB_SEARCH_AUTO_PARAMETERS=true
WEB_SEARCH_INCLUDE_USAGE=false
JINA_READ_ENABLED=true
JINA_READ_BASE_URL=https://r.jina.ai
SEARXNG_SEARCH_ENABLED=true
# 复用上方基础设施配置中的 SEARXNG_BASE_URL
SEARXNG_DEFAULT_CATEGORIES=[]
SEARXNG_DEFAULT_LANGUAGE=
SEARXNG_DEFAULT_ENGINES=[]
WEB_EXTRACT_DEFAULT_DEPTH=basic
WEB_CRAWL_DEFAULT_DEPTH=basic
WEB_CRAWL_DEFAULT_LIMIT=10
WEB_CRAWL_DEFAULT_MAX_DEPTH=3
WEB_CRAWL_DEFAULT_MAX_BREADTH=20
WEB_RESEARCH_OUTPUT_FORMAT=report
WEB_RESEARCH_CITATION_FORMAT=numbered
WEB_RESEARCH_POLL_INTERVAL_SECONDS=2

# 向量嵌入（Embedding）
EMBEDDING_BASE_URL=https://your-openai-compatible-endpoint/v1
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_MODEL=your-embedding-model
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_DIM=4096

# HTTP 客户端（统一超时/连接池）
HTTP_TIMEOUT_CONNECT_SECONDS=5
HTTP_TIMEOUT_READ_SECONDS=30
HTTP_TIMEOUT_WRITE_SECONDS=30
HTTP_TIMEOUT_POOL_SECONDS=5
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE_CONNECTIONS=20
HTTP_KEEPALIVE_EXPIRY_SECONDS=5

# Milvus 集合
MILVUS_COLLECTION=kb_chunks_v1

# MinIO 客户端
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_UPLOADS=mkb-uploads
MINIO_BUCKET_EXPORTS=mkb-exports
EXPORTS_PRESIGN_EXPIRE_SECONDS=3600

# CORS 跨域
APP_CORS_ALLOW_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# MCP（扩展能力，默认关闭）
MCP_ENABLED=true
MCP_CONFIRMATION_REQUIRED=true
MCP_STREAMABLE_HTTP=true
MCP_HTTP_TIMEOUT_SECONDS=30
MCP_STDIO_TIMEOUT_SECONDS=30

# DeepAgents / 记忆
DEEPAGENTS_ENABLED=true
MEMORY_ENABLED=true
MEMORY_STORE_BACKEND=postgres
MEMORY_STORE_URL=postgresql://mkb:mkb@localhost:5433/mkb
MEMORY_STORE_PATH=/memories/

# 检索配置
RETRIEVAL_DEFAULT_TOP_K=12
RETRIEVAL_MAX_TOP_K=50
RETRIEVAL_CACHE_TTL_SECONDS=300
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_MIN_SCORE=0.2
RETRIEVAL_QUERY_LOWERCASE=false
RETRIEVAL_HYBRID_RANKER=rrf
RETRIEVAL_HYBRID_DENSE_WEIGHT=0.6
RETRIEVAL_HYBRID_SPARSE_WEIGHT=0.4
RETRIEVAL_HYBRID_RRF_K=60
RETRIEVAL_QUERY_REWRITE_TIMEOUT_SECONDS=600
RETRIEVAL_QUERY_REWRITE_MAX_TOKENS=512
RETRIEVAL_RERANK_BASE_URL=https://your-openai-compatible-endpoint/v1
RETRIEVAL_RERANK_API_KEY=your-rerank-api-key
RETRIEVAL_RERANK_MODEL=your-rerank-model
RETRIEVAL_RERANK_TIMEOUT_SECONDS=60
KB_CHAT_SEMANTIC_CACHE_ENABLED=true
KB_CHAT_SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.88
KB_CHAT_SEMANTIC_CACHE_TTL_SECONDS=86400
KB_CHAT_SEMANTIC_CACHE_MAX_ITEMS=128
KB_CHAT_HYDE_ENABLED=true

# 上下文预算配置
CONTEXT_HISTORY_MAX_MESSAGES=6

# 对话摘要配置
SUMMARY_ENABLED=true
SUMMARY_TRIGGER_MIN_MESSAGES=12
SUMMARY_TRIGGER_MIN_TOKENS=800
SUMMARY_MAX_TOKENS=512

# 上下文增强（默认开启）
INGESTION_CONTEXTUAL_ENABLED=true
INGESTION_CONTEXTUAL_MAX_TOKENS=192
INGESTION_CONTEXTUAL_CONCURRENCY=2
INGESTION_EMBEDDING_BATCH_SIZE=32
