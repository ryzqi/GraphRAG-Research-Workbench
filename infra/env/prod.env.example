# Production placeholder values for podman-compose.base.yml + podman-compose.prod.example.yml.
# Inject real secrets from a secrets manager, file-secret mount, or platform environment.

TZ=UTC
COMMON_NO_PROXY=<cluster-internal-no-proxy-list>
SEARXNG_NO_PROXY=<cluster-internal-no-proxy-list>

POSTGRES_USER=<db-user>
POSTGRES_PASSWORD=<set-via-secret-manager>
POSTGRES_DB=<db-name>
POSTGRES_PORT=5432

REDIS_PORT=6379
ETCD_PORT=2379

MINIO_ROOT_USER=<set-via-secret-manager>
MINIO_ROOT_PASSWORD=<set-via-secret-manager>
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

MILVUS_PORT=19530
MILVUS_HTTP_PORT=9091

SEARXNG_PORT=8080
SEARXNG_BASE_URL=https://<searxng-public-host>/
SEARXNG_SECRET=<set-via-secret-manager>
SEARXNG_LIMITER=true
SEARXNG_PUBLIC_INSTANCE=false
SEARXNG_IMAGE_PROXY=true
SEARXNG_VALKEY_URL=valkey://searxng_valkey:6379/0
