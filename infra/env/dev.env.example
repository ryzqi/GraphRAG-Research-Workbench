# Local development defaults for infra/up.ps1.
# Copy to infra/env/dev.env only when you need to override these values.

TZ=Asia/Shanghai
COMMON_NO_PROXY=localhost,127.0.0.1,postgres,redis,minio,milvus,etcd,*.local,10.*,172.16.*,172.17.*,172.18.*,172.19.*,172.30.*,172.31.*,192.168.*
SEARXNG_NO_PROXY=localhost,127.0.0.1,postgres,redis,minio,milvus,etcd,searxng,searxng_valkey,*.local,10.*,172.16.*,172.17.*,172.18.*,172.19.*,172.30.*,172.31.*,192.168.*

POSTGRES_USER=mkb_dev
POSTGRES_PASSWORD=mkb_dev_password
POSTGRES_DB=mkb_dev
POSTGRES_PORT=5433

REDIS_PORT=6379
ETCD_PORT=2379

MINIO_ROOT_USER=mkb-dev-root
MINIO_ROOT_PASSWORD=mkb-dev-root-password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

MILVUS_PORT=19530
MILVUS_HTTP_PORT=9091

SEARXNG_PORT=18080
SEARXNG_BASE_URL=http://searxng.localtest.me:18080/
SEARXNG_SECRET=mkb-dev-searxng-secret
SEARXNG_LIMITER=false
SEARXNG_PUBLIC_INSTANCE=false
SEARXNG_IMAGE_PROXY=false
SEARXNG_VALKEY_URL=valkey://searxng_valkey:6379/0
